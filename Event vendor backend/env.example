PORT=4000
JWT_SECRET=replace-with-a-long-random-secret-string

# ── Database ─────────────────────────────────────────────────────────────
# Set this to use Postgres. Leave blank to use the local JSON store (dev only).
# Neon:     postgres://USER:PASSWORD@HOST/DB?sslmode=require
# Supabase: postgres://postgres:PASSWORD@HOST:5432/postgres
DATABASE_URL=
# Set to "false" only for a local Postgres without SSL
DATABASE_SSL=true
DB_POOL_MAX=10

# Comma-separated origins allowed to call the API (your frontend URL)
CORS_ORIGIN=http://localhost:5173

# Admin moderation: secret key for admin-only endpoints (delete/suspend accounts)
ADMIN_KEY=change-me-strong-random-string

# Human verification (optional). Set both to enforce CAPTCHA on signup.
CAPTCHA_SECRET=
CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# Base URL used in verification emails
APP_URL=http://localhost:5173

# Payments (optional; demo mode unless set). See README → Payments.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SPONSORED=
